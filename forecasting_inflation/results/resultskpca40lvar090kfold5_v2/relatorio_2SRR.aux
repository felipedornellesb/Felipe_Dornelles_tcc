\newlabel{fig:betas_top2}{{8}{10}{Evolução dos coeficientes TVP dos 2 componentes PCA com maior volatilidade ao longo do tempo ($h=1$). Esses são os fatores que mais ``trabalham'' na adaptação do modelo às mudanças de regime macroeconômico}{figure.caption.10}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3}Sinal e magnitude dos principais componentes PCA}{10}{subsection.3.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Evolução de $\hat  {\beta }(t)$ para PC1, PC2 e PC3 ao longo de todo o período OOS, $h=1$. PC1 e PC2 são os dois maiores eixos de variação do FRED-MD. Mudanças de sinal evidenciam instabilidade estrutural na relação macro-inflação.}}{10}{figure.caption.11}\protected@file@percent }
\newlabel{fig:betas_pc1_pc2}{{9}{10}{Evolução de $\hat {\beta }(t)$ para PC1, PC2 e PC3 ao longo de todo o período OOS, $h=1$. PC1 e PC2 são os dois maiores eixos de variação do FRED-MD. Mudanças de sinal evidenciam instabilidade estrutural na relação macro-inflação}{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Top 6 componentes PCA por volatilidade dos coeficientes ($h=1$). Cada painel mostra a série $\hat  {\beta }_{PC_k}(t)$ com faixa de confiança. A variância entre componentes revela quais dimensões do espaço macro são mais instáveis ao longo do tempo.}}{11}{figure.caption.12}\protected@file@percent }
\newlabel{fig:betas_top6}{{10}{11}{Top 6 componentes PCA por volatilidade dos coeficientes ($h=1$). Cada painel mostra a série $\hat {\beta }_{PC_k}(t)$ com faixa de confiança. A variância entre componentes revela quais dimensões do espaço macro são mais instáveis ao longo do tempo}{figure.caption.12}{}}
