\@writefile{toc}{\contentsline {subsection}{\numberline {2.1}RMSFE relativo ao Random Walk --- todos os modelos}{3}{subsection.2.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces RMSFE relativo ao Random Walk para todos os 13 modelos ($h = 1$ a $h = 12$). A linha tracejada em 1{,}0 representa o benchmark. O 2SRR é o único modelo que fica abaixo de 1{,}0 em \textbf  {todos} os 12 horizontes individuais. O Bagging é o que mais destoa negativamente, superando o benchmark em múltiplos horizontes.}}{3}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:rmsfe_todos}{{1}{3}{RMSFE relativo ao Random Walk para todos os 13 modelos ($h = 1$ a $h = 12$). A linha tracejada em 1{,}0 representa o benchmark. O 2SRR é o único modelo que fica abaixo de 1{,}0 em \textbf {todos} os 12 horizontes individuais. O Bagging é o que mais destoa negativamente, superando o benchmark em múltiplos horizontes}{figure.caption.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces RMSFE relativo ao Random Walk com significância Diebold-Mariano. Asteriscos indicam significância do teste DM bilateral, comparando cada modelo \textbf  {contra o 2SRR}: * $p<0{,}10$; ** $p<0{,}05$; *** $p<0{,}01$. \textbf  {Negrito} = menor RMSFE por linha. Valores $< 1$ indicam ganho sobre o benchmark RW. Hiperparâmetros 2SRR: $K_{\max }=40$, variância $\geq 90\%$, $k$-fold~$=5$. 312 janelas OOS (Jan/1960--Jun/2025).}}{4}{table.caption.3}\protected@file@percent }
\newlabel{tab:rmsfe_dm}{{1}{4}{RMSFE relativo ao Random Walk com significância Diebold-Mariano. Asteriscos indicam significância do teste DM bilateral, comparando cada modelo \textbf {contra o 2SRR}: * $p<0{,}10$; ** $p<0{,}05$; *** $p<0{,}01$. \textbf {Negrito} = menor RMSFE por linha. Valores $< 1$ indicam ganho sobre o benchmark RW. Hiperparâmetros 2SRR: $K_{\max }=40$, variância $\geq 90\%$, $k$-fold~$=5$. 312 janelas OOS (Jan/1960--Jun/2025)}{table.caption.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.2}Como ler o teste Diebold-Mariano nessa tabela}{4}{subsection.2.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {2.3}2SRR vs.\ Ridge --- o ganho da variação temporal}{5}{subsection.2.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces RMSFE relativo ao RW: 2SRR vs.\ Ridge por horizonte. O Ridge homogêneo é o benchmark natural para o 2SRR, pois é algebricamente equivalente ao 2SRR com $\lambda \to \infty $ (parâmetros congelados). Onde o 2SRR ganha, significa que deixar os parâmetros variar ajudou.}}{5}{figure.caption.4}\protected@file@percent }
\newlabel{fig:2srr_ridge}{{2}{5}{RMSFE relativo ao RW: 2SRR vs.\ Ridge por horizonte. O Ridge homogêneo é o benchmark natural para o 2SRR, pois é algebricamente equivalente ao 2SRR com $\lambda \to \infty $ (parâmetros congelados). Onde o 2SRR ganha, significa que deixar os parâmetros variar ajudou}{figure.caption.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.4}2SRR vs.\ modelos selecionados}{6}{subsection.2.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces RMSFE relativo ao RW: 2SRR vs.\ modelos selecionados (Ridge, ElNET, RF) por horizonte. Comparação enxuta com os três rivais mais relevantes --- o benchmark natural (Ridge), o melhor modelo estático nos horizontes curtos (ElNET) e o melhor modelo nos horizontes longos (Random Forest).}}{6}{figure.caption.5}\protected@file@percent }
\newlabel{fig:2srr_selecionados}{{3}{6}{RMSFE relativo ao RW: 2SRR vs.\ modelos selecionados (Ridge, ElNET, RF) por horizonte. Comparação enxuta com os três rivais mais relevantes --- o benchmark natural (Ridge), o melhor modelo estático nos horizontes curtos (ElNET) e o melhor modelo nos horizontes longos (Random Forest)}{figure.caption.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.5}Análise por sub-períodos}{7}{subsection.2.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces RMSFE por sub-período histórico (Grande Inflação, Grande Moderação, Crise Financeira Global, Pós-pandemia). A decomposição temporal revela em quais regimes macroeconômicos o 2SRR se beneficia da adaptabilidade dos parâmetros.}}{7}{figure.caption.6}\protected@file@percent }
\newlabel{fig:subperiodos}{{4}{7}{RMSFE por sub-período histórico (Grande Inflação, Grande Moderação, Crise Financeira Global, Pós-pandemia). A decomposição temporal revela em quais regimes macroeconômicos o 2SRR se beneficia da adaptabilidade dos parâmetros}{figure.caption.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.6}Ranking Borda --- desempenho agregado}{7}{subsection.2.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Ranking Borda agregado por modelo ao longo de todos os horizontes ($h=1$ a $h=12$). Menor pontuação = melhor desempenho médio no ranking. O Borda Count é uma métrica de consenso que penaliza modelos instáveis entre horizontes.}}{7}{figure.caption.7}\protected@file@percent }
\newlabel{fig:borda}{{5}{7}{Ranking Borda agregado por modelo ao longo de todos os horizontes ($h=1$ a $h=12$). Menor pontuação = melhor desempenho médio no ranking. O Borda Count é uma métrica de consenso que penaliza modelos instáveis entre horizontes}{figure.caption.7}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {2.7}CSFE --- Quando o 2SRR ganha e quando perde}{8}{subsection.2.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces CSFE acumulado para $h=1$: diferença acumulada entre o erro quadrático do benchmark (RW) e o erro quadrático do 2SRR. Linha ascendente = 2SRR está vencendo; linha descendente = 2SRR está perdendo. As sombras cinzas indicam recessões NBER.}}{8}{figure.caption.8}\protected@file@percent }
\newlabel{fig:csfe}{{6}{8}{CSFE acumulado para $h=1$: diferença acumulada entre o erro quadrático do benchmark (RW) e o erro quadrático do 2SRR. Linha ascendente = 2SRR está vencendo; linha descendente = 2SRR está perdendo. As sombras cinzas indicam recessões NBER}{figure.caption.8}{}}
