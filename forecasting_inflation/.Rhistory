# Em uma nova sessão — não interfere no loop rodando
setwd("C:/Users/felip/OneDrive/Documentos/tcc/Felipe_Dornelles_tcc/forecasting_inflation")
library(here)
library(glmnet)
library(rugarch)
library(tidyverse)
source("functions/functions.R")
source("functions/tvp_ridge_functions.R")
load("data/data.rda")
dates <- data$date
df    <- data %>% select(-date) %>% as.matrix()
rownames(df) <- as.character(dates)
# Testa uma janela do meio e uma do fim
t0 <- proc.time()
r1 <- run2srr(1:180, df, "CPIAUCSL", horizon = 1)
cat(sprintf("Janela inicio: %.1fs\n", (proc.time()-t0)[3]))
t0 <- proc.time()
r2 <- run2srr(400:585, df, "CPIAUCSL", horizon = 1)
cat(sprintf("Janela meio: %.1fs\n", (proc.time()-t0)[3]))
t0 <- proc.time()
r3 <- run2srr(600:785, df, "CPIAUCSL", horizon = 1)
cat(sprintf("Janela fim: %.1fs\n", (proc.time()-t0)[3]))
model_name <- "2SRR"
nwindows   <- 180
model_list <- list()
t_total    <- proc.time()
for (i in 1:12) {
cat(sprintf("[%s] Rodando horizonte h = %d ...\n",
format(Sys.time(), "%H:%M:%S"), i))
t0 <- proc.time()
model_list[[i]] <- rolling_window(
run2srr, df, nwindows + i - 1, i, "CPIAUCSL"
)
cat(sprintf("[%s] h = %d concluido em %.1f min\n",
format(Sys.time(), "%H:%M:%S"), i,
(proc.time() - t0)[3] / 60))
}
cat(sprintf("\nTotal: %.1f min\n", (proc.time() - t_total)[3] / 60))
# Consolida
forecasts <- Reduce(
cbind,
lapply(model_list, function(x) head(x$forecast, nwindows))
)
forecasts <- accumulate_model(forecasts)
# Recarrega o que faltou
source("functions/rolling_window.R")
# Reinicia o loop do zero
model_list <- list()
t_total    <- proc.time()
for (i in 1:12) {
cat(sprintf("[%s] Rodando horizonte h = %d ...\n",
format(Sys.time(), "%H:%M:%S"), i))
t0 <- proc.time()
model_list[[i]] <- rolling_window(
run2srr, df, nwindows + i - 1, i, "CPIAUCSL"
)
cat(sprintf("[%s] h = %d concluido em %.1f min\n",
format(Sys.time(), "%H:%M:%S"), i,
(proc.time() - t0)[3] / 60))
}
View(df)
# Salva df (matriz sem coluna date, com rownames = datas)
df_export <- as.data.frame(df)
df_export <- cbind(date = rownames(df_export), df_export)
write.csv(df_export, file = "results/df_matrix.csv", row.names = FALSE)
cat(sprintf("df salvo: %d obs x %d variaveis em results/df_matrix.csv\n",
nrow(df), ncol(df)))
# Salva data (data.frame original com coluna date)
write.csv(data, file = "results/data_original.csv", row.names = FALSE)
cat(sprintf("data salvo: %d obs x %d variaveis em results/data_original.csv\n",
nrow(data), ncol(data)))
load("~/tcc/Felipe_Dornelles_tcc/forecasting_inflation/forecasts/Ridge.rda")
View(forecasts)
