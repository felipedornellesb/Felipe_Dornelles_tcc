distinct(date, .keep_all = TRUE)
cat(sprintf("    -> DESEMPREGO total: %d obs.\n", nrow(df_out)))
return(df_out)
}
bind_rows(df_pme, df_pnadc) |>
arrange(date) |>
distinct(date, .keep_all = TRUE)
}
